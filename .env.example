# Runtime mode controls whether browser-side debug token inputs are available.
# production = BFF-only; no MCP/Vercel token is stored or sent by the browser.
VITE_RUNTIME_MODE=development

# Development default: Vite dev server proxy. Production: set this to the BFF URL.
VITE_MCP_URL=/
VITE_MCP_PROXY_TARGET=https://github-unified-mcp.onrender.com

# Do not add MCP_TOKEN or Vercel tokens here. Production credentials belong in the BFF.
