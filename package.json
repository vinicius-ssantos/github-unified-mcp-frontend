{
  "name": "github-unified-mcp-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:ui": "playwright test",
    "test:ui:headed": "playwright test --headed",
    "test:visual": "VISUAL_REGRESSION=1 playwright test tests/ui/console-visual.spec.ts",
    "test:visual:update": "VISUAL_REGRESSION=1 playwright test tests/ui/console-visual.spec.ts --update-snapshots"
  },
  "dependencies": {
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "typescript": "latest",
    "vite": "latest"
  }
}
